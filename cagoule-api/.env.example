# cagoule-api — Variables d'environnement
# Copier vers .env et remplir CAGOULE_API_KEY avant de démarrer

# Obligatoire — clé d'authentification Bearer
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
CAGOULE_API_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# Optionnel — réseau
CAGOULE_HOST=127.0.0.1
CAGOULE_PORT=8000

# Optionnel — mTLS (1 = activé)
CAGOULE_MTLS=0
CAGOULE_SSL_KEY=certs/server.key
CAGOULE_SSL_CERT=certs/server.crt
CAGOULE_SSL_CA=certs/ca.crt

# Optionnel — limite taille fichier en MB
FILE_SIZE_LIMIT_MB=10
