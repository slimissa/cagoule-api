# ────────────────────────────────────────────────────────────────
# cagoule-api — Variables d'environnement
# Copier vers .env et remplir les valeurs avant de démarrer
# 
# ⚠️  Ne JAMAIS committer le fichier .env réel !
# ────────────────────────────────────────────────────────────────

# ================================================================
# OBLIGATOIRE
# ================================================================

# Clé d'authentification Bearer (requise)
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 caractères recommandé
CAGOULE_API_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# ================================================================
# RÉSEAU
# ================================================================

# Hôte d'écoute (127.0.0.1 = localhost uniquement, 0.0.0.0 = toutes les interfaces)
CAGOULE_HOST=127.0.0.1

# Port d'écoute
CAGOULE_PORT=8000

# ================================================================
# mTLS (Authentification mutuelle TLS)
# ================================================================

# Activer mTLS (1 = activé, 0 = désactivé)
CAGOULE_MTLS=0

# Chemins des certificats (requis si CAGOULE_MTLS=1)
CAGOULE_SSL_KEY=certs/server.key      # Clé privée du serveur
CAGOULE_SSL_CERT=certs/server.crt     # Certificat du serveur
CAGOULE_SSL_CA=certs/ca.crt           # Autorité de certification

# Générer les certificats avec : bash scripts/gen_certs.sh

# ================================================================
# LIMITES
# ================================================================

# Taille maximale des fichiers en MB (pour /v1/encrypt/file)
FILE_SIZE_LIMIT_MB=10

# ================================================================
# LOGGING (optionnel)
# ================================================================

# Niveau de log (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# ================================================================
# DOCKER (optionnel)
# ================================================================

# URL de l'API pour les clients (ex: http://cagoule-api:8000)
# CAGOULE_API_URL=http://localhost:8000